# ============================================================
# WhatsApp AI Automation System — Environment Template
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# ---------- Core ----------
NODE_ENV=development
TZ=Asia/Colombo

# ---------- Backend API ----------
BACKEND_PORT=4000
BACKEND_PUBLIC_URL=http://localhost:4000
JWT_SECRET=replace-with-32-byte-random-hex
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=change-me-on-first-login

# ---------- Admin Dashboard ----------
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-32-byte-random-hex

# ---------- PostgreSQL ----------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=whatsapp_shop
POSTGRES_USER=shop
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://shop:change-me@postgres:5432/whatsapp_shop?schema=public

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ---------- Qdrant ----------
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=chat_memory

# ---------- n8n ----------
N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me
N8N_ENCRYPTION_KEY=replace-with-32-byte-random-hex
WEBHOOK_URL=http://localhost:5678

# ---------- WhatsApp Cloud API ----------
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=replace-with-random-string
WHATSAPP_APP_SECRET=
WHATSAPP_API_VERSION=v20.0

# ---------- LLM Providers ----------
# Pick one. Anthropic recommended for tool use.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_CLASSIFIER_MODEL=claude-haiku-4-5-20251001

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Embeddings (used for Qdrant)
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# ---------- Feature Flags ----------
ENABLE_HUMAN_HANDOFF=true
ENABLE_BROADCASTS=true
ENABLE_RAG_MEMORY=true
MAX_TURNS_PER_CONVERSATION=20
RATE_LIMIT_MSG_PER_5MIN=30
